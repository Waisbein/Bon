# === Required for Telegram admin bot ===
TELEGRAM_BOT_TOKEN=PASTE_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_WEBHOOK_SECRET=PASTE_RANDOM_SECRET_STRING_HERE
TELEGRAM_ADMIN_IDS=467914417

# === Required for GitHub publishing ===
GITHUB_TOKEN=PASTE_GITHUB_PAT_HERE
GITHUB_REPO_OWNER=Waisbein
GITHUB_REPO_NAME=Bon
GITHUB_TARGET_BRANCH=main

# Optional: separate branch for bot state/drafts (defaults to target branch)
GITHUB_DRAFT_BRANCH=main

# === Paths inside repo (keep defaults unless you really need custom) ===
BOT_STATE_PATH=.bot/menu-drafts.json
MENU_DATA_PATH=public/menu/admin-items.json
MENU_UPLOAD_DIR=public/menu/uploads

# === Required for webhook setup helper endpoint ===
APP_BASE_URL=https://YOUR-VERCEL-DOMAIN.vercel.app
